# edu-broadcast 本地密钥配置示例
# 复制本文件为 secrets.yaml 并填入真实值：
#   cp config/secrets.yaml.example config/secrets.yaml
#
# secrets.yaml 已在 .gitignore 中排除，不会被提交到代码仓库

# AI4Scholar MCP 接口（论文采集）
mcp_url: "https://mcp.ai4scholar.net/sse"
mcp_token: "YOUR_MCP_TOKEN"

# LLM 配置（新闻/论文筛选）
llm_api_key: "YOUR_LLM_API_KEY"
llm_base_url: "https://api.moonshot.cn/v1"
llm_model: "kimi-k2-turbo-preview"

# 飞书多维表格配置
feishu_app_id: "YOUR_FEISHU_APP_ID"
feishu_app_secret: "YOUR_FEISHU_APP_SECRET"
feishu_bitable_app_token: "YOUR_BITABLE_APP_TOKEN"
feishu_bitable_table_id_papers: "YOUR_TABLE_ID_PAPERS"
feishu_bitable_table_id_news: "YOUR_TABLE_ID_NEWS"
